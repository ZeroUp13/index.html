<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Mini Battle Royale 3D</title>

<style>
body{
    margin:0;
    overflow:hidden;
    touch-action:none;
}

#joystick{
    position:absolute;
    left:20px;
    bottom:20px;
    width:140px;
    height:140px;
    border-radius:50%;
    background:rgba(255,255,255,.15);
}

#stick{
    position:absolute;
    width:60px;
    height:60px;
    left:40px;
    top:40px;
    border-radius:50%;
    background:white;
}

#shoot{
    position:absolute;
    right:30px;
    bottom:40px;
    width:100px;
    height:100px;
    border:none;
    border-radius:50%;
    background:red;
    color:white;
    font-size:28px;
}
</style>
</head>
<body>

<div id="joystick">
    <div id="stick"></div>
</div>

<button id="shoot">🔥</button>

<script src="https://cdn.jsdelivr.net/npm/three@0.160.0/build/three.min.js"></script>

<script>

const scene = new THREE.Scene();
scene.background = new THREE.Color(0x87ceeb);

const camera = new THREE.PerspectiveCamera(
75,
window.innerWidth/window.innerHeight,
0.1,
1000
);

const renderer = new THREE.WebGLRenderer({antialias:true});
renderer.setSize(window.innerWidth,window.innerHeight);
document.body.appendChild(renderer.domElement);

const light = new THREE.DirectionalLight(0xffffff,2);
light.position.set(10,20,10);
scene.add(light);

const ground = new THREE.Mesh(
new THREE.PlaneGeometry(100,100),
new THREE.MeshLambertMaterial({color:0x4caf50})
);
ground.rotation.x=-Math.PI/2;
scene.add(ground);

const player = new THREE.Mesh(
new THREE.BoxGeometry(1,2,1),
new THREE.MeshLambertMaterial({color:0x0000ff})
);

player.position.y=1;
scene.add(player);

const enemy = new THREE.Mesh(
new THREE.BoxGeometry(1,2,1),
new THREE.MeshLambertMaterial({color:0xff0000})
);

enemy.position.set(0,1,-15);
scene.add(enemy);

camera.position.set(0,8,8);
camera.lookAt(player.position);

const bullets=[];

function shoot(){

    const bullet = new THREE.Mesh(
        new THREE.SphereGeometry(0.15),
        new THREE.MeshBasicMaterial({color:0xffff00})
    );

    bullet.position.copy(player.position);

    bullet.velocity =
    new THREE.Vector3(0,0,-0.7);

    bullets.push(bullet);
    scene.add(bullet);
}

document.getElementById("shoot")
.addEventListener("touchstart",shoot);

document.getElementById("shoot")
.addEventListener("click",shoot);

let moveX=0;
let moveY=0;

const joystick=document.getElementById("joystick");
const stick=document.getElementById("stick");

joystick.addEventListener("touchmove",(e)=>{

    const rect=joystick.getBoundingClientRect();
    const touch=e.touches[0];

    let x=touch.clientX-rect.left-70;
    let y=touch.clientY-rect.top-70;

    const max=50;
    const dist=Math.sqrt(x*x+y*y);

    if(dist>max){
        x=x/dist*max;
        y=y/dist*max;
    }

    moveX=x/max;
    moveY=y/max;

    stick.style.left=(40+x)+"px";
    stick.style.top=(40+y)+"px";

});

joystick.addEventListener("touchend",()=>{

    moveX=0;
    moveY=0;

    stick.style.left="40px";
    stick.style.top="40px";

});

function animate(){

    requestAnimationFrame(animate);

    player.position.x += moveX*0.15;
    player.position.z += moveY*0.15;

    camera.position.x=player.position.x;
    camera.position.z=player.position.z+8;

    camera.lookAt(player.position);

    bullets.forEach((b,index)=>{

        b.position.add(b.velocity);

        if(
            b.position.distanceTo(enemy.position)
            < 1
        ){
            enemy.position.set(
                (Math.random()*30)-15,
                1,
                -20-Math.random()*20
            );
        }

        if(b.position.z<-100){
            scene.remove(b);
            bullets.splice(index,1);
        }
    });

    renderer.render(scene,camera);
}

animate();

window.addEventListener("resize",()=>{

    camera.aspect=
    window.innerWidth/window.innerHeight;

    camera.updateProjectionMatrix();

    renderer.setSize(
        window.innerWidth,
        window.innerHeight
    );
});

</script>

</body>
</html>
